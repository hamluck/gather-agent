# Anthropic (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Bot Configuration
BOT_NAME=기획자 Claude
BOT_STATUS=NPC에게 말을 걸어보세요!

# Server
EXPRESS_PORT=3000
ALLOWED_ORIGINS=https://app.gather.town,https://gather.town

# Storage
DB_PATH=./data/gather-agent.db

# Gather Town (optional — setup-npc script only)
GATHER_API_KEY=
GATHER_SPACE_ID=

# Notion (optional — tasks/meetings sync)
NOTION_API_KEY=
NOTION_TASKS_DB_ID=
NOTION_MEETINGS_DB_ID=

# Slack (optional — notifications)
SLACK_WEBHOOK_URL=

# Rate Limiting
CLAUDE_MAX_REQUESTS_PER_MINUTE=60
CLAUDE_MAX_REQUESTS_PER_USER_PER_MINUTE=10
CLAUDE_MAX_REQUESTS_PER_DAY=1000
CLAUDE_MAX_CONCURRENT=5
MAX_REQUESTS_PER_IP_PER_MINUTE=20
